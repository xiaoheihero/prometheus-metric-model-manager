    "/metrics/import": {
      "get": {
        "tags": ["指标管理"],
        "summary": "显示导入指标表单",
        "responses": {
          "200": {
            "description": "导入指标表单页面"
          }
        }
      },
      "post": {
        "tags": ["指标管理"],
        "summary": "导入指标",
        "description": "从Prometheus数据源导入指标及其标签",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["dataSourceId", "metricName"],
                "properties": {
                  "dataSourceId": {
                    "type": "integer",
                    "description": "数据源ID"
                  },
                  "metricName": {
                    "type": "string",
                    "description": "指标名称"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "导入成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "labelCount": {
                      "type": "integer"
                    },
                    "redirectUrl": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误"
          },
          "404": {
            "description": "数据源不存在"
          },
          "500": {
            "description": "服务器错误"
          }
        }
      }
    },
    "/metrics/datasource/{id}/metrics": {
      "get": {
        "tags": ["指标管理"],
        "summary": "获取数据源的所有指标",
        "description": "从指定数据源获取所有可用的指标名称",
