          },
          {
            "name": "collector",
            "in": "query",
            "description": "采集器（模糊搜索）",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "owner",
            "in": "query",
            "description": "责任人（模糊搜索）",
