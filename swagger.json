{
  "openapi": "3.0.0",
  "info": {
    "title": "Prometheus Metric Model Manager API",
    "description": "Prometheus指标模型管理工具API文档",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "本地开发服务器"
    }
  ],
  "tags": [
    {
      "name": "数据源管理",
      "description": "数据源的增删改查和测试"
    },
    {
      "name": "指标管理",
      "description": "指标的导入、编辑、删除和查询"
    },
    {
      "name": "标签管理",
      "description": "标签的增删改查"
    },
    {
      "name": "导出功能",
      "description": "指标的预览和导出"
    }
  ],
  "paths": {
    "/datasources": {
      "get": {
        "tags": ["数据源管理"],
        "summary": "获取数据源列表",
        "description": "获取所有数据源，支持分页和搜索",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "数据源名称（模糊搜索）",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回数据源列表页面"
          },
          "500": {
            "description": "服务器错误"
          }
        }
      }
    },
    "/datasources/test": {
      "post": {
        "tags": ["数据源管理"],
        "summary": "测试数据源连接",
        "description": "测试数据源配置是否可以成功连接Prometheus",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "url"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "数据源名称"
                  },
                  "url": {
                    "type": "string",
                    "description": "Prometheus URL"
                  },
                  "authType": {
                    "type": "string",
                    "enum": ["none", "basic", "bearer"],
                    "default": "none",
                    "description": "认证类型"
                  },
                  "username": {
                    "type": "string",
                    "description": "Basic认证用户名"
                  },
                  "password": {
                    "type": "string",
                    "description": "Basic认证密码"
                  },
                  "headerKeys": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "自定义Header键列表"
                  },
                  "headerValues": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "自定义Header值列表"
                  },
                  "skipTlsVerify": {
                    "type": "boolean",
                    "default": false,
                    "description": "是否跳过TLS验证"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "测试结果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "是否成功"
                    },
                    "message": {
                      "type": "string",
                      "description": "结果消息"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "服务器错误"
          }
        }
      }
    },
    "/datasources/test/{id}": {
      "post": {
        "tags": ["数据源管理"],
        "summary": "测试已保存的数据源",
        "description": "测试指定ID的数据源是否可以成功连接",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "数据源ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "测试结果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "数据源不存在"
          },
          "500": {
            "description": "服务器错误"
          }
        }
      }
    },
    "/datasources/add": {
      "get": {
        "tags": ["数据源管理"],
        "summary": "显示添加数据源表单",
        "description": "返回添加数据源的页面",
