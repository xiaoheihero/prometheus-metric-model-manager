          "200": {
            "description": "添加数据源表单页面"
          }
        }
      },
      "post": {
        "tags": ["数据源管理"],
        "summary": "添加数据源",
        "description": "创建新的数据源",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "url"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "数据源名称"
                  },
                  "url": {
                    "type": "string",
                    "description": "Prometheus URL"
                  },
                  "authType": {
                    "type": "string",
                    "enum": ["none", "basic", "bearer"],
                    "default": "none"
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "headerKeys": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "headerValues": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "skipTlsVerify": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "重定向到数据源列表"
          },
          "500": {
            "description": "服务器错误"
          }
        }
      }
    },
    "/datasources/edit/{id}": {
      "get": {
        "tags": ["数据源管理"],
        "summary": "显示编辑数据源表单",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "编辑数据源表单页面"
          },
          "404": {
            "description": "数据源不存在"
          }
        }
      },
      "post": {
        "tags": ["数据源管理"],
        "summary": "更新数据源",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "url"],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "authType": {
                    "type": "string",
                    "enum": ["none", "basic", "bearer"]
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "headerKeys": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "headerValues": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "skipTlsVerify": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "重定向到数据源列表"
          },
          "404": {
            "description": "数据源不存在"
          },
          "500": {
            "description": "服务器错误"
          }
        }
      }
    },
    "/datasources/delete/{id}": {
      "get": {
        "tags": ["数据源管理"],
        "summary": "删除数据源",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "重定向到数据源列表"
