<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>数据源</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .status-badge.success {
            background-color: #d4edda;
            color: #155724;
        }
        
        .status-badge.warning {
            background-color: #fff3cd;
            color: #856404;
        }
        
        .status-badge.secondary {
            background-color: #e2e3e5;
            color: #383d41;
        }
        
        .status-badge.danger {
            background-color: #f8d7da;
            color: #721c24;
        }
        
        .test-result {
            margin-top: 10px;
            padding: 10px 15px;
            border-radius: 6px;
            font-size: 14px;
        }
        
        .test-result.success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }
        
        .test-result.error {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
        
        .test-result.loading {
            background-color: #fff3cd;
            color: #856404;
            border: 1px solid #ffc107;
        }
        
        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            padding: 15px;
            background-color: #f9f9f9;
            border-radius: 6px;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .pagination-info {
            color: #666;
        }
        
        .pagination-controls {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .pagination-controls label {
            white-space: nowrap;
            display: flex;
            align-items: center;
        }
        
        .page-info {
            padding: 0 10px;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="nav">
        <div class="container">
            <ul>
                <li><a href="/">首页</a></li>
                <li><a href="/datasources">数据源</a></li>
                <li><a href="/metrics">指标</a></li>
            </ul>
        </div>
    </div>
    
    <div class="container">
        <h1>数据源</h1>
        
        <div class="card">
            <h2>数据源列表</h2>
            <div class="mb-20">
                <a href="/datasources/add" class="button">添加数据源</a>
            </div>
            <div class="card" style="padding: 15px;">
                <h3>搜索数据源</h3>
                <form action="/datasources" method="get" style="display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;">
                    <div class="form-group" style="flex: 1; min-width: 200px; margin-bottom: 0;">
                        <label for="name">名称</label>
                        <input type="text" id="name" name="name" placeholder="输入数据源名称" value="<%= searchName %>">
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <input type="submit" value="搜索" class="button success">
                        <a href="/datasources" class="button secondary ml-10">重置</a>
                    </div>
                </form>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>名称</th>
                        <th>URL</th>
                        <th>认证类型</th>
                        <th>跳过 TLS 验证</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (dataSources.length > 0) { %>
                        <% dataSources.forEach(dataSource => { %>
                        <tr id="row-<%= dataSource.id %>">
                            <td><%= dataSource.id %></td>
                            <td><%= dataSource.name %></td>
                            <td><%= dataSource.url %></td>
                            <td>
                                <% if (dataSource.auth_type === 'basic') { %>
                                    <span class="status-badge warning">基本认证</span>
                                <% } else { %>
                                    <span class="status-badge secondary">无认证</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (dataSource.skip_tls_verify == 1) { %>
                                    <span class="status-badge danger">是</span>
                                <% } else { %>
                                    <span class="status-badge success">否</span>
                                <% } %>
                            </td>
                            <td>
                                <button type="button" class="button small" onclick="testDataSource(<%= dataSource.id %>)">测试</button>
                                <a href="/datasources/edit/<%= dataSource.id %>" class="button small ml-5">编辑</a>
                                <a href="/datasources/delete/<%= dataSource.id %>" class="button small danger ml-5" onclick="return confirm('确定要删除吗？');">删除</a>
                            </td>
                        </tr>
                        <tr id="test-result-row-<%= dataSource.id %>" style="display: none;">
                            <td colspan="6">
                                <div id="test-result-<%= dataSource.id %>" class="test-result"></div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="text-align: center;">暂无数据源，请添加数据源</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
            
            <% if (totalPages > 1) { %>
            <div class="pagination">
                <div class="pagination-info">
                    共 <%= total %> 条记录，第 <%= currentPage %> / <%= totalPages %> 页
                </div>
                <div class="pagination-controls">
                    <label style="margin-right: 10px;">
                        每页
                        <select id="pageSize" onchange="changePageSize()" style="margin: 0 5px;">
                            <option value="10" <%= pageSize == 10 ? 'selected' : '' %>>10</option>
                            <option value="20" <%= pageSize == 20 ? 'selected' : '' %>>20</option>
                            <option value="50" <%= pageSize == 50 ? 'selected' : '' %>>50</option>
                            <option value="100" <%= pageSize == 100 ? 'selected' : '' %>>100</option>
                        </select>
                        条
                    </label>
                    
                    <% if (currentPage > 1) { %>
                        <a href="?page=1&pageSize=<%= pageSize %><%= searchName ? '&name=' + encodeURIComponent(searchName) : '' %>" class="button small">首页</a>
                        <a href="?page=<%= currentPage - 1 %>&pageSize=<%= pageSize %><%= searchName ? '&name=' + encodeURIComponent(searchName) : '' %>" class="button small">上一页</a>
                    <% } %>
                    
                    <span class="page-info"><%= currentPage %> / <%= totalPages %></span>
                    
                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %>&pageSize=<%= pageSize %><%= searchName ? '&name=' + encodeURIComponent(searchName) : '' %>" class="button small">下一页</a>
                        <a href="?page=<%= totalPages %>&pageSize=<%= pageSize %><%= searchName ? '&name=' + encodeURIComponent(searchName) : '' %>" class="button small">末页</a>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </div>
    
    <script>
        function changePageSize() {
            const pageSize = document.getElementById('pageSize').value;
            let url = '?page=1&pageSize=' + pageSize;
            const searchName = '<%= searchName %>';
            if (searchName) {
                url += '&name=' + encodeURIComponent(searchName);
            }
            window.location.href = url;
        }
        
        function testDataSource(id) {
            const resultRow = document.getElementById(`test-result-row-${id}`);
            const resultDiv = document.getElementById(`test-result-${id}`);
            
            resultRow.style.display = 'table-row';
            resultDiv.className = 'test-result loading';
            resultDiv.innerHTML = '正在测试数据源连接...';
            
            fetch(`/datasources/test/${id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    resultDiv.className = 'test-result success';
                    resultDiv.innerHTML = '✓ 测试成功: ' + data.message;
                } else {
                    resultDiv.className = 'test-result error';
                    resultDiv.innerHTML = '✗ 测试失败: ' + data.message;
                }
            })
            .catch(error => {
                resultDiv.className = 'test-result error';
                resultDiv.innerHTML = '✗ 测试失败: ' + error.message;
            });
        }
    </script>
</body>
</html>
